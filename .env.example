# Copy to .env.local and fill in.
# Generate SESSION_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=replace-with-64-char-hex
VAULT_DB_PATH=./data/vault.db

# Session lifetime in minutes (auto-lock window)
SESSION_TTL_MINUTES=30

# Node env
NODE_ENV=development
